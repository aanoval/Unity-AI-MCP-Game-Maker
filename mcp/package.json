{
  "name": "unity-ai-mcp-game-maker-server",
  "version": "0.1.0",
  "description": "MCP stdio adapter for Unity AI MCP Game Maker.",
  "type": "module",
  "bin": {
    "unity-ai-game-maker-mcp": "./dist/src/server.js"
  },
  "engines": {
    "node": ">=20"
